{
  "name": "hivemux",
  "version": "1.5.0",
  "description": "Linux-native, tmux-backed orchestrator for parallel AI coding agents in isolated git worktrees.",
  "type": "module",
  "bin": {
    "hivemux": "dist/hivemux"
  },
  "scripts": {
    "dev": "bun src/cli.ts",
    "build": "bun build src/cli.ts --compile --outfile dist/hivemux",
    "start": "./dist/hivemux",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src package.json biome.json",
    "lint:fix": "biome check --write src package.json biome.json",
    "format": "biome format --write src",
    "test": "bun test src",
    "test:e2e": "playwright test",
    "pack": "bunx repomix --output hivemux.repomix.txt",
    "check": "bun run typecheck && bun run lint && bun test src"
  },
  "engines": {
    "bun": ">=1.1"
  },
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.61.0",
    "@types/bun": "^1.1.0",
    "typescript": "^5.5.4"
  }
}
