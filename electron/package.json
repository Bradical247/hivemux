{
  "name": "hivemux-desktop",
  "version": "1.1.0",
  "description": "hivemux — desktop app (Linux): parallel AI coding agents in a native window.",
  "main": "main.js",
  "license": "MIT",
  "author": "Conrad Bachman",
  "homepage": "https://github.com/Bradical247/hivemux",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --linux AppImage deb --publish never"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "io.hivemux.desktop",
    "productName": "hivemux",
    "files": ["main.js", "icon.png"],
    "extraResources": [
      { "from": "resources/hivemux", "to": "hivemux" },
      { "from": "resources/ttyd", "to": "ttyd" }
    ],
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Development",
      "icon": "icon.png",
      "maintainer": "Conrad Bachman <108717148+Bradical247@users.noreply.github.com>",
      "description": "Linux-native, tmux-backed orchestrator for parallel AI coding agents."
    }
  }
}
