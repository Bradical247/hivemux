  "os": ["linux", "darwin"],
  "cpu": ["x64", "arm64"],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Bradical247/hivemux.git"
  },
  "homepage": "https://github.com/Bradical247/hivemux#readme",
  "bugs": "https://github.com/Bradical247/hivemux/issues",
  "keywords": [
    "ai",
    "agents",
    "claude",
    "tmux",
    "orchestrator",
    "coding-agent",
    "mcp",
    "cli",
    "parallel"
  ],
