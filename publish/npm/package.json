{
  "name": "hivemux",
  "version": "1.6.0",
  "description": "Linux-native, tmux-backed orchestrator for parallel AI coding agents in isolated git worktrees.",
  "bin": {
    "hivemux": "bin/hivemux.cjs"
  },
  "scripts": {
    "postinstall": "node scripts/postinstall.cjs"
  },
  "files": [
    "bin/hivemux.cjs",
    "scripts/postinstall.cjs",
